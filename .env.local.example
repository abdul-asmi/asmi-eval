GEMINI_API_KEY=your-new-gemini-api-key
GEMINI_MODEL=models/gemini-3.1-flash-lite-preview
REMOTE_UI_URL=https://asmi-eval.onrender.com
DAEMON_TOKEN=ask-admin-for-this
DAEMON_OWNER_USER_ID=paste-your-user-id-here

# ── ElevenLabs call_eval (end-to-end call testing) ─────────────────────────────
# 1. Buy a Twilio voice number (twilio.com)
# 2. Create an ElevenLabs Conversational AI agent; enable system_prompt overrides
# 3. Import your Twilio number in ElevenLabs → Phone Numbers → Import → Twilio
# 4. Fill in the three vars below
ELEVENLABS_API_KEY=xi-...
ELEVENLABS_AGENT_ID=agent_...
CALL_EVAL_PHONE=+14125551234   # Twilio number Asmi will call during tests
# CALL_TRANSCRIPT_TIMEOUT=240  # optional: seconds to wait for call to finish

# Optional: enforce a hard connected-call cap via Twilio REST API.
# Needed for automatic hangup at N seconds (default in app is 100s).
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# CALL_EVAL_MAX_DURATION=100
